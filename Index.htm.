<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Executa">
<title>Executa</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  :root {
    --bg: #f5f5f5;
    --card: #ffffff;
    --text: #111111;
    --muted: #999999;
    --border: #e8e8e8;
    --green: #22c55e;
    --green-light: #f0fdf4;
    --red: #ef4444;
    --blue: #3b82f6;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    max-width: 430px;
    margin: 0 auto;
  }

  .header {
    background: var(--card);
    padding: 52px 20px 20px;
    border-bottom: 1px solid var(--border);
  }

  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .greeting {
    font-size: 13px;
    color: var(--muted);
    font-weight: 400;
    margin-bottom: 2px;
  }

  .day-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.5px;
  }

  .streak-pill {
    display: flex;
    align-items: center;
    gap: 5px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 20px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    color: #ea580c;
  }

  .progress-section {
    background: var(--card);
    padding: 16px 20px 20px;
    border-bottom: 1px solid var(--border);
  }

  .progress-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .progress-text { font-size: 13px; color: var(--muted); font-weight: 500; }
  .progress-count { font-size: 13px; font-weight: 700; color: var(--text); }

  .progress-bar {
    height: 6px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--green);
    border-radius: 99px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    width: 0%;
  }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 20px 20px 10px;
  }

  .tasks {
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .task {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px;
    background: var(--card);
    border-radius: 14px;
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
  }

  .task:active { transform: scale(0.98); }

  .task.done {
    background: var(--green-light);
    border-color: #bbf7d0;
  }

  .check {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--border);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .task.done .check {
    background: var(--green);
    border-color: var(--green);
  }

  .check-icon {
    opacity: 0;
    transition: all 0.2s ease;
    transform: scale(0.8);
  }

  .task.done .check-icon {
    opacity: 1;
    transform: scale(1);
  }

  .task-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    flex: 1;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .task.done .task-text {
    color: var(--muted);
    text-decoration: line-through;
    text-decoration-color: #86efac;
  }

  .task-delete {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ddd;
    font-size: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .task-delete:active { color: var(--red); }

  .add-section {
    padding: 12px 16px 0;
    display: flex;
    gap: 8px;
  }

  .add-input {
    flex: 1;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 13px 16px;
    outline: none;
    transition: border-color 0.15s;
  }

  .add-input::placeholder { color: var(--muted); font-weight: 400; }
  .add-input:focus { border-color: var(--blue); }

  .add-btn {
    background: var(--text);
    border: none;
    color: white;
    font-size: 22px;
    font-weight: 300;
    width: 50px;
    height: 50px;
    border-radius: 12px;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s;
  }

  .add-btn:active { opacity: 0.7; }

  .all-done-banner {
    margin: 12px 16px 0;
    background: var(--green-light);
    border: 1.5px solid #bbf7d0;
    border-radius: 14px;
    padding: 18px;
    text-align: center;
    display: none;
  }

  .all-done-banner.show { display: block; }
  .all-done-emoji { font-size: 28px; margin-bottom: 6px; }
  .all-done-text { font-size: 14px; font-weight: 700; color: #15803d; }
  .all-done-sub { font-size: 12px; color: #4ade80; margin-top: 2px; }

  .history-toggle {
    margin: 20px 16px 0;
    width: calc(100% - 32px);
    padding: 14px 16px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.15s;
  }

  .history-toggle:active { background: var(--bg); }
  .history-arrow { transition: transform 0.2s; font-style: normal; display: inline-block; }
  .history-toggle.open .history-arrow { transform: rotate(180deg); }

  .history-panel { display: none; padding: 12px 16px 0; }
  .history-panel.open { display: block; }

  .history-day {
    background: var(--card);
    border-radius: 12px;
    border: 1.5px solid var(--border);
    padding: 14px 16px;
    margin-bottom: 8px;
  }

  .history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .history-date { font-size: 12px; font-weight: 700; color: var(--text); }

  .history-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 99px;
  }

  .history-badge.done { background: var(--green-light); color: #16a34a; }
  .history-badge.miss { background: #fef2f2; color: var(--red); }

  .history-task-item {
    font-size: 12px;
    color: var(--muted);
    padding: 3px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .history-task-item.done { color: #4ade80; }
  .history-task-item.done::before { content: '✓'; color: var(--green); }
  .history-task-item.miss::before { content: '✗'; color: #fca5a5; color: var(--muted); }

  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--text);
    color: white;
    padding: 12px 20px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 100;
    pointer-events: none;
  }

  .toast.show { transform: translateX(-50%) translateY(0); }
  .toast.green { background: var(--green); }

  .bottom-space { height: 80px; }
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<div class="header">
  <div class="header-top">
    <div>
      <div class="greeting" id="greeting">Bom dia, Filipe</div>
      <div class="day-title" id="dayTitle">—</div>
    </div>
    <div class="streak-pill">🔥 <span id="streakNum">0</span> dias</div>
  </div>
</div>

<div class="progress-section">
  <div class="progress-info">
    <div class="progress-text">Progresso de hoje</div>
    <div class="progress-count" id="progressCount">0/0</div>
  </div>
  <div class="progress-bar">
    <div class="progress-fill" id="progressFill"></div>
  </div>
</div>

<div class="all-done-banner" id="allDoneBanner">
  <div class="all-done-emoji">✅</div>
  <div class="all-done-text">Dia completo.</div>
  <div class="all-done-sub">É isso que separa você dos outros.</div>
</div>

<div class="section-label">Tarefas de hoje</div>
<div class="tasks" id="taskList"></div>

<div class="add-section">
  <input class="add-input" id="newTaskInput" placeholder="Adicionar tarefa...">
  <button class="add-btn" onclick="addTask()">+</button>
</div>

<button class="history-toggle" id="histBtn" onclick="toggleHistory()">
  Histórico <i class="history-arrow">▾</i>
</button>
<div class="history-panel" id="histPanel"></div>

<div class="bottom-space"></div>

<script>
const DAYS = ['Domingo','Segunda-feira','Terça-feira','Quarta-feira','Quinta-feira','Sexta-feira','Sábado'];
const MONTHS = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
const DEFAULTS = ["Instagram profissional público","Postar logo reveal Gillette","Trabalhar no segundo reels"];

const getToday = () => new Date().toISOString().split('T')[0];
const load = () => { try { return JSON.parse(localStorage.getItem('executa_v2')||'null'); } catch { return null; } };
const save = s => localStorage.setItem('executa_v2', JSON.stringify(s));

function init() {
  let s = load();
  const today = getToday();
  if (!s) {
    s = { tasks: DEFAULTS.map((t,i)=>({id:i,text:t,done:false})), nextId:DEFAULTS.length, history:{}, streak:0, lastCompleted:null, currentDay:today };
  }
  if (s.currentDay !== today) {
    const allDone = s.tasks.length > 0 && s.tasks.every(t=>t.done);
    s.history[s.currentDay] = { tasks: s.tasks.map(t=>({text:t.text,done:t.done})), allDone };
    if (allDone) {
      const prev = new Date(today); prev.setDate(prev.getDate()-1);
      const prevStr = prev.toISOString().split('T')[0];
      s.streak = (s.lastCompleted===prevStr||s.lastCompleted===s.currentDay) ? (s.streak||0)+1 : 1;
      s.lastCompleted = s.currentDay;
    } else { s.streak = 0; }
    s.tasks = s.tasks.map(t=>({...t,done:false}));
    s.currentDay = today;
    save(s);
  }
  return s;
}

let state = init();

function render() {
  const now = new Date();
  const h = now.getHours();
  document.getElementById('greeting').textContent = h<12?'Bom dia, Filipe':h<18?'Boa tarde, Filipe':'Boa noite, Filipe';
  document.getElementById('dayTitle').textContent = DAYS[now.getDay()];

  const list = document.getElementById('taskList');
  list.innerHTML = '';
  state.tasks.forEach(task => {
    const el = document.createElement('div');
    el.className = 'task'+(task.done?' done':'');
    el.innerHTML = `
      <div class="check">
        <svg class="check-icon" width="12" height="10" viewBox="0 0 12 10" fill="none">
          <path d="M1 5L4.5 8.5L11 1.5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="task-text">${task.text}</div>
      <div class="task-delete" data-id="${task.id}">×</div>
    `;
    el.querySelector('.task-delete').addEventListener('click', e => { e.stopPropagation(); deleteTask(task.id); });
    el.addEventListener('click', () => toggleTask(task.id));
    list.appendChild(el);
  });

  const done = state.tasks.filter(t=>t.done).length;
  const total = state.tasks.length;
  document.getElementById('progressFill').style.width = total>0?(done/total*100)+'%':'0%';
  document.getElementById('progressCount').textContent = `${done}/${total}`;
  document.getElementById('streakNum').textContent = state.streak||0;
  document.getElementById('allDoneBanner').classList.toggle('show', total>0&&done===total);

  renderHistory();
}

function toggleTask(id) {
  const t = state.tasks.find(t=>t.id===id); if(!t) return;
  t.done = !t.done;
  const allDone = state.tasks.length>0&&state.tasks.every(t=>t.done);
  if (allDone) showToast('Dia completo. 🔥', true);
  else if (t.done) showToast('Feito ✓');
  save(state); render();
}

function deleteTask(id) {
  state.tasks = state.tasks.filter(t=>t.id!==id);
  save(state); render();
}

function addTask() {
  const input = document.getElementById('newTaskInput');
  const text = input.value.trim(); if(!text) return;
  state.tasks.push({id:state.nextId++,text,done:false});
  input.value = ''; save(state); render();
}

document.getElementById('newTaskInput').addEventListener('keydown', e => { if(e.key==='Enter') addTask(); });

function toggleHistory() {
  document.getElementById('histPanel').classList.toggle('open');
  document.getElementById('histBtn').classList.toggle('open');
}

function renderHistory() {
  const panel = document.getElementById('histPanel');
  const days = Object.keys(state.history||{}).sort().reverse();
  if (!days.length) { panel.innerHTML='<div style="font-size:13px;color:#ccc;padding:8px 4px;text-align:center;">Nenhum histórico ainda.</div>'; return; }
  panel.innerHTML = days.map(day => {
    const e = state.history[day];
    const d = new Date(day+'T12:00:00');
    const label = `${d.getDate()} ${MONTHS[d.getMonth()]} — ${DAYS[d.getDay()]}`;
    return `<div class="history-day">
      <div class="history-header">
        <div class="history-date">${label}</div>
        <div class="history-badge ${e.allDone?'done':'miss'}">${e.allDone?'Completo':'Incompleto'}</div>
      </div>
      ${e.tasks.map(t=>`<div class="history-task-item ${t.done?'done':'miss'}">${t.text}</div>`).join('')}
    </div>`;
  }).join('');
}

let toastT;
function showToast(msg, green) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show'+(green?' green':'');
  clearTimeout(toastT);
  toastT = setTimeout(()=>el.classList.remove('show'), 2000);
}

render();
</script>
</body>
  </html>
